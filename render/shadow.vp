#version 140

in highp vec4 position;

out mediump vec2 var_pos;

uniform vs_uniforms
{
    mediump mat4 mtx_worldviewproj;
};

void main()
{
    // quad vertices span -0.5..0.5 in XZ, use as local coord for circle
    var_pos = position.xz;
    gl_Position = mtx_worldviewproj * vec4(position.xyz, 1.0);
}
